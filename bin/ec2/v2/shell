#!/bin/bash

# Requires the `session-manager-plugin` to be installed:
# https://docs.aws.amazon.com/systems-manager/latest/userguide/session-manager-working-with-install-plugin.html

# exit on failures
set -e
set -o pipefail

usage() {
  echo "Usage: $(basename "$0") [OPTIONS]" 1>&2
  echo "  -h                     - help"
  echo "  -i <infrastructure>    - infrastructure name (used to resolve account)"
  echo "  -e <environment>       - environment name (e.g. 'staging' or 'prod')"
  echo "  -a <account>           - dalmatian account name (used to resolve account)"
  echo "  -p <profile>           - aws profile name"
  echo "  -l                     - list available ec2 instance ids"
  echo "  -I <instance_id>       - ec2 instance id"
  exit 1
}

# if there are no arguments passed exit with usage
if [ $# -eq 0 ]
then
 usage
fi

if ! command -v session-manager-plugin > /dev/null
then
  err "This script requires the \`session-manager-plugin\` to be installed"
  log_msg -l "https://docs.aws.amazon.com/systems-manager/latest/userguide/session-manager-working-with-install-plugin.html" -q "$QUIET_MODE"
  exit 1
fi

INFRASTRUCTURE_NAME=""
ENVIRONMENT=""
DALMATIAN_ACCOUNT_NAME=""
AWS_SSO_PROFILE=""
LIST_ONLY=""
INSTANCE_ID=""

while getopts "i:e:a:p:lI:h" opt; do
  case $opt in
    i)
      INFRASTRUCTURE_NAME=$OPTARG
      ;;
    e)
      ENVIRONMENT=$OPTARG
      ;;
    a)
      DALMATIAN_ACCOUNT_NAME=$OPTARG
      ;;
    p)
      AWS_SSO_PROFILE=$OPTARG
      ;;
    l)
      LIST_ONLY=1
      ;;
    I)
      INSTANCE_ID=$OPTARG
      ;;
    h)
      usage
      ;;
    *)
      usage
      ;;
  esac
done

# Resolve profile
if [ -n "$AWS_SSO_PROFILE" ]
then
  PROFILE="$AWS_SSO_PROFILE"
elif [[
  ( -n "$INFRASTRUCTURE_NAME" && -n "$ENVIRONMENT" ) ||
  -n "$DALMATIAN_ACCOUNT_NAME"
]]
then
  PROFILE="$(resolve_aws_profile -i "$INFRASTRUCTURE_NAME" -e "$ENVIRONMENT" -a "$DALMATIAN_ACCOUNT_NAME")"
else
  usage
fi

log_info -l "Finding instances in account profile '$PROFILE'..." -q "$QUIET_MODE"

INSTANCES=$(
  "$APP_ROOT/bin/dalmatian" aws run-command \
  -p "$PROFILE" \
  ec2 describe-instances \
  --filters Name=instance-state-code,Values=16
)

RESERVATIONS="$(echo "$INSTANCES" | jq -r '.Reservations[]')"
if [ -z "$RESERVATIONS" ]
then
  err "No running instances found in profile '$PROFILE'"
  exit 1
fi

AVAILABLE_INSTANCES=$(echo "$RESERVATIONS" | jq -r '.Instances[] |
  (.InstanceId) + " | " +
    ((.Tags[]? | select(.Key == "Name") | .Value) // "No Name") + " | " +
  (.LaunchTime)')

if [ -n "$LIST_ONLY" ]
then
  echo "$AVAILABLE_INSTANCES"
  exit 0
fi

if [ -n "$INSTANCE_ID" ]
then
  # Verify instance ID
  INSTANCE_NAME=$(echo "$INSTANCES" | jq -r --arg i "$INSTANCE_ID" \
    '.Reservations[].Instances[] | select(.InstanceId == $i) | (.Tags[]? | select(.Key == "Name") | .Value) // "No Name"')
  if [ -z "$INSTANCE_NAME" ]
  then
    err "Instance ID '$INSTANCE_ID' was not found or is not running"
    log_msg -l "Available instances:" -q "$QUIET_MODE"
    echo "$AVAILABLE_INSTANCES"
    exit 1
  fi
else
  # Count instances
  INSTANCE_COUNT=$(echo "$INSTANCES" | jq -r '[.Reservations[].Instances[]] | length')
  
  if [ "$INSTANCE_COUNT" -eq 1 ]
  then
    INSTANCE_ID=$(echo "$INSTANCES" | jq -r '.Reservations[0].Instances[0].InstanceId')
    INSTANCE_NAME=$(echo "$INSTANCES" | jq -r '.Reservations[0].Instances[0] | (.Tags[]? | select(.Key == "Name") | .Value) // "No Name"')
  else
    # Interactive choice
    log_msg -l "Multiple instances found. Please choose one:" -q "$QUIET_MODE"
    
    if [[ "${DALMATIAN_FZF_ENABLED:-1}" == "1" ]] && command -v fzf > /dev/null
    then
      OPT=$(echo "$AVAILABLE_INSTANCES" | fzf --height 40% --reverse --header "Select an instance")
      if [ -z "$OPT" ]
      then
        err "No instance selected"
        exit 1
      fi
      INSTANCE_ID=$(echo "$OPT" | cut -d' ' -f1)
      INSTANCE_NAME=$(echo "$OPT" | cut -d'|' -f2 | xargs)
    else
      # Store instances in an array for selection
      mapfile -t INSTANCE_LIST < <(echo "$AVAILABLE_INSTANCES")
      
      PS3="Select an instance (1-${#INSTANCE_LIST[@]}): "
      select OPT in "${INSTANCE_LIST[@]}"
      do
        if [ -n "$OPT" ]
        then
          INSTANCE_ID=$(echo "$OPT" | cut -d' ' -f1)
          INSTANCE_NAME=$(echo "$OPT" | cut -d'|' -f2 | xargs)
          break
        else
          echo "Invalid selection"
        fi
      done
    fi
  fi
fi

log_info -l "Connecting to '$INSTANCE_NAME' (id: $INSTANCE_ID)..." -q "$QUIET_MODE"

"$APP_ROOT/bin/dalmatian" aws run-command \
  -p "$PROFILE" \
  ssm start-session --target "$INSTANCE_ID"
